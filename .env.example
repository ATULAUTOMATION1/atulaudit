# Application Base URL
NEXT_PUBLIC_APP_URL=https://audit.atulautomation.com

# Supabase Credentials (Postgres Database with RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google PageSpeed Insights API Key
GOOGLE_PAGESPEED_API_KEY=your-google-pagespeed-api-key

# Direct Google Sheets Integration (Google Apps Script Web App URL)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your-google-apps-script-deployment-id/exec

# Direct WhatsApp Integration (Meta Cloud API / Interakt / WATI / Aisensy)
WHATSAPP_API_URL=https://api.interakt.ai/v1/public/message/
WHATSAPP_API_KEY=your-whatsapp-api-key

# Direct Email Integration (Resend)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=reports@atulautomation.com
TEAM_NOTIFICATION_EMAIL=hello@atulautomation.com

# Optional n8n Webhook Fallback
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/xxx

# Local Development Demo Mode (Set to true to run offline without Supabase/PageSpeed API keys)
DEMO_MODE=false
